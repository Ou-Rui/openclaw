# 在openclaw基础镜像上, 安装pip和tavily-cli工具, 实现网页搜索
ARG BASE_IMAGE=ghcr.io/openclaw/openclaw:latest
FROM ${BASE_IMAGE}

USER root

RUN set -eux; \
  curl -fsSL --retry 3 --retry-delay 2 --connect-timeout 20 https://bootstrap.pypa.io/get-pip.py -o /tmp/get-pip.py; \
  python3 /tmp/get-pip.py --break-system-packages; \
  python3 -m pip install --no-cache-dir --break-system-packages tavily-cli; \
  rm -f /tmp/get-pip.py; \
  rm -rf /var/lib/apt/lists/*
